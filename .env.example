# Kiro 自动注册环境变量模板
# 使用方式：复制为 .env 或 .env.local，然后填入真实配置。
# 注意：.env 里会包含密钥，不要提交到 Git。

# =============================
# kiro.rs 自动发布
# =============================
# 是否把注册成功后的 AWS Builder ID 授权自动发布到 kiro.rs。
KIRO_RS_UPLOAD_ENABLED=true

# kiro.rs 后台地址，脚本会自动兼容 /admin 后缀。
KIRO_RS_ADMIN_URL=https://kiro.leftcode.xyz/admin

# kiro.rs 后台 API Key。兼容变量名：KIRO_RS_SK / KIRO_RS_API_KEY / ADMIN_API_KEY。
KIRO_RS_ADMIN_KEY=sk-change-me

# AWS Builder ID 授权区域，一般保持 us-east-1。
KIRO_AUTH_REGION=us-east-1

# 上传到 kiro.rs 的凭据优先级，默认 0。
KIRO_RS_PRIORITY=0

# 上传到 kiro.rs 的可选覆盖项，一般留空。
KIRO_RS_ENDPOINT=
KIRO_RS_AUTH_REGION=
KIRO_RS_API_REGION=

# =============================
# 临时邮箱渠道
# =============================
# 选择邮箱渠道：
#   cloudflare-temp-email = 使用自建 Cloudflare Temp Email（默认）
#   gptmail               = 使用 https://mail.chatgpt.org.uk API
TEMP_MAIL_PROVIDER=cloudflare-temp-email

# =============================
# Cloudflare Temp Email 临时邮箱
# =============================
# 当 TEMP_MAIL_PROVIDER=cloudflare-temp-email 时使用。
# 脚本使用：
#   POST /admin/new_address
#   GET  /admin/mails?address=<邮箱>&limit=20&offset=0

# Cloudflare Temp Email 服务地址。
CLOUDFLARE_TEMP_EMAIL_BASE_URL=https://your-cloudflare-temp-email.example.com

# 管理密码，请求头为 x-admin-auth。
CLOUDFLARE_TEMP_EMAIL_ADMIN_AUTH=change-me-admin-auth

# 可选自定义密码；如果你的服务没有开启 x-custom-auth，就留空。
CLOUDFLARE_TEMP_EMAIL_CUSTOM_AUTH=

# 邮箱生成方式：
#   random = 调用 /admin/new_address 随机生成邮箱（默认）
#   pool   = 从 CLOUDFLARE_TEMP_EMAIL_POOL_PATH 指定的 txt 邮箱池取邮箱
CLOUDFLARE_TEMP_EMAIL_MODE=random

# random 模式：创建邮箱使用的域名，例如 example.com。
CLOUDFLARE_TEMP_EMAIL_DOMAIN=example.com

# random 模式：是否启用随机子域名；一般保持 false。
CLOUDFLARE_TEMP_EMAIL_USE_RANDOM_SUBDOMAIN=false

# pool 模式：邮箱池 txt 路径，每行一个邮箱，例如：
#   xxx@aaa.com
#   bbb@aaa.com
CLOUDFLARE_TEMP_EMAIL_POOL_PATH=txt/cloudflare-temp-email-pool.txt

# pool 模式：固定查信的接收邮箱。注册时使用邮箱池里的邮箱，查询验证码时查这个邮箱。
# 例如：icloud@scveq.com
CLOUDFLARE_TEMP_EMAIL_POOL_RECEIVER=

# =============================
# GPTMail 临时邮箱
# =============================
# 当 TEMP_MAIL_PROVIDER=gptmail 时使用。
# API 文档：https://mail.chatgpt.org.uk/zh/api
# 脚本使用：
#   POST/GET /api/generate-email
#   GET      /api/emails?email=<邮箱>

# GPTMail 服务地址，默认就是 https://mail.chatgpt.org.uk。
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk

# GPTMail API Key，请填你自己的 key；不要把真实 key 提交到 Git。
GPTMAIL_API_KEY=

# 可选：指定生成邮箱的域名；留空则由 GPTMail 随机分配。
GPTMAIL_DOMAIN=

# 可选：指定生成邮箱前缀；留空则随机生成。
GPTMAIL_PREFIX=


# =============================
# Kiro PRO 试用资格检测
# =============================
# 是否在 AWS Builder ID 注册成功后自动检测 Kiro PRO 试用资格。
# 开启后只会走到 Stripe Checkout 金额判断：付款金额为 0 代表有试用资格，然后立刻停止，不提交付款，也不发布 kiro.rs。
KIRO_AUTO_PRO_TRIAL=false

# PRO 检测读取的输入目录。
# 注册流程会直接使用刚注册成功的邮箱和密码；只有单独跑检测且没有传入账号时，才会从 邮箱.txt 取账号。
# 资格检测只读取 checkout 订单金额，不需要 信用卡.txt。
KIRO_PRO_TXT_DIR=txt

# PRO 检测专用浏览器 profile；默认每次清理。需要复用登录态时设置 KIRO_PRO_REUSE_PROFILE=true。
KIRO_PRO_PROFILE_DIR=.browser-profile/kiro-pro-trial
KIRO_PRO_REUSE_PROFILE=false

# PRO 检测结果和事件日志输出。
KIRO_PRO_RESULT_PATH=show/pro-trial-result.json
KIRO_PRO_EVENTS_PATH=artifacts/pro-trial-events.ndjson

# =============================
# 可选代理
# =============================
# 也可以启动时通过 --proxy 传入。
HTTP_PROXY=
HTTPS_PROXY=
