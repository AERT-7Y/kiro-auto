# Kiro 自动注册环境变量模板
# 使用方式：复制为 .env 或 .env.local，然后填入真实配置。
# 注意：.env 里会包含密钥，不要提交到 Git。

# =============================
# kiro.rs 自动发布
# =============================
# 是否把注册成功后的 AWS Builder ID 授权自动发布到 kiro.rs。
KIRO_RS_UPLOAD_ENABLED=true

# kiro.rs 后台地址，脚本会自动兼容 /admin 后缀。
KIRO_RS_ADMIN_URL=https://kiro.leftcode.xyz/admin

# kiro.rs 后台 API Key。兼容变量名：KIRO_RS_SK / KIRO_RS_API_KEY / ADMIN_API_KEY。
KIRO_RS_ADMIN_KEY=sk-change-me

# AWS Builder ID 授权区域，一般保持 us-east-1。
KIRO_AUTH_REGION=us-east-1

# 上传到 kiro.rs 的凭据优先级，默认 0。
KIRO_RS_PRIORITY=0

# 上传到 kiro.rs 的可选覆盖项，一般留空。
KIRO_RS_ENDPOINT=
KIRO_RS_AUTH_REGION=
KIRO_RS_API_REGION=

# =============================
# Cloudflare Temp Email 临时邮箱
# =============================
# 只支持这一种邮箱渠道。
# 脚本使用：
#   POST /admin/new_address
#   GET  /admin/mails?address=<邮箱>&limit=20&offset=0

# Cloudflare Temp Email 服务地址。
CLOUDFLARE_TEMP_EMAIL_BASE_URL=https://your-cloudflare-temp-email.example.com

# 管理密码，请求头为 x-admin-auth。
CLOUDFLARE_TEMP_EMAIL_ADMIN_AUTH=change-me-admin-auth

# 可选自定义密码；如果你的服务没有开启 x-custom-auth，就留空。
CLOUDFLARE_TEMP_EMAIL_CUSTOM_AUTH=

# 创建邮箱使用的域名，例如 example.com。
CLOUDFLARE_TEMP_EMAIL_DOMAIN=example.com

# 是否启用随机子域名；一般保持 false。
CLOUDFLARE_TEMP_EMAIL_USE_RANDOM_SUBDOMAIN=false

# =============================
# 可选代理
# =============================
# 也可以启动时通过 --proxy 传入。
HTTP_PROXY=
HTTPS_PROXY=
